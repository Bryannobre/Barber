# =============================================================================
# VARIÁVEIS DE AMBIENTE — BeautyHub SaaS
# Copie para .env.local e preencha os valores
# =============================================================================

# --- FRONTEND (expostas ao client via Vite - NUNCA coloque senhas aqui) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key
# Opcional: use "true" para desativar auth quando Supabase estiver inacessível (ex: projeto pausado, URL inválida)
# Evita erros repetidos no console (ERR_NAME_NOT_RESOLVED, Failed to fetch)
# VITE_SUPABASE_DISABLED=false

# --- BACKEND / MIGRATIONS (NUNCA usar prefixo VITE_) ---
# Connection string PostgreSQL - usada APENAS para migrations (scripts locais)
# Obtenha em: Supabase Dashboard > Settings > Database > Connection string (URI)
# Use a opção "Session pooler" (porta 6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# Opcional: para seed de usuários (local/scripts)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# --- EDGE FUNCTIONS (Supabase hosted - NUNCA expor no frontend) ---
# SUPABASE_SERVICE_ROLE_KEY e SUPABASE_URL já estão disponíveis automaticamente
# nas Edge Functions em produção. Não é necessário configurar manualmente.
#
# Secret opcional no Dashboard (Edge Functions → Secrets): ALLOWED_ORIGINS
# Se definir em produção, inclua TODAS as origens do app, ex.:
# ALLOWED_ORIGINS=https://app.seudominio.com,http://26.157.142.156:3080
# Sem esse secret, Edge Functions aceitam localhost + IP:3080/5173 (dev/VPN).
# Lista separada por vírgula dos domínios que podem chamar a função (CORS), ex.:
# ALLOWED_ORIGINS=https://app.seudominio.com,https://www.seudominio.com
# Em local, o código já permite localhost:3080 e 5173 se ALLOWED_ORIGINS não existir.
